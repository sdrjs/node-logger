# Logger configuration
LOG_PATH=logs                       # Directory for log files
LOG_SIZE=5 * 1024 * 1024            # Max size of log files in bytes; supports '*' expressions, e.g., '10*1024*1024' = 10 MB
LOG_FILES=5                         # Number of backup log files to keep (0 = disable rotation)
LOG_DEBUG=false                     # Enable debug logs; set to 'true' or '1' to enable

# Archive script configuration
LOG_ARCHIVE_VERBOSE=false           # Enable verbose logging for the archive script; set to 'true' or '1'
LOG_ARCHIVE_LOCK_TIMEOUT=30         # Lock file timeout in minutes; supports '*' expressions, e.g., '60 * 24' = 24 hours